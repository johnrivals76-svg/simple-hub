-- MENU FUNCTIONS
local function makeToggle(name,posY,callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,30)
    btn.Position = UDim2.new(0,0,0,posY)
    btn.Text = name
    btn.TextColor3 = Color3.new(1,1,1)
    btn.BackgroundColor3 = Color3.fromRGB(35,35,35)
    btn.Parent = menu
    btn.MouseButton1Click:Connect(callback)
end

local function makeSlider(name,posY,min,max,initial,callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,20)
    label.Position = UDim2.new(0,0,0,posY)
    label.Text = name.." : "..initial
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Parent = menu

    local slider = Instance.new("Frame")
    slider.Size = UDim2.new(1,0,0,20)
    slider.Position = UDim2.new(0,0,0,posY+20)
    slider.BackgroundColor3 = Color3.fromRGB(60,60,60)
    slider.Parent = menu

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((initial-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(200,200,200)
    fill.Parent = slider

    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local function move(input2)
                local pos = math.clamp((input2.Position.X - slider.AbsolutePosition.X)/slider.AbsoluteSize.X,0,1)
                fill.Size = UDim2.new(pos,0,1,0)
                local value = min + pos*(max-min)
                label.Text = name.." : "..string.format("%.2f", value)
                callback(value)
            end
            move(input)
            local conn
            conn = UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == input.UserInputType then
                    move(i)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == input.UserInputType then
                    conn:Disconnect()
                end
            end)
        end
    end)
end

